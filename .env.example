# .env.example — copy this to .env and fill in real values
# Never commit .env to version control.

# REQUIRED — Flask session signing key.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 1 locally, leave blank (or 0) in production.
FLASK_DEBUG=0

# Optional — absolute path to the SQLite DB file.
# Defaults to concert.db in the project directory if left blank.
# On PythonAnywhere set this to e.g. /home/<username>/myproject/concert.db
DB_PATH=
